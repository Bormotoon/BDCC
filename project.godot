; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5


[application]

config/name="BDCC"
run/main_scene="res://UI/LaunchScreen/LaunchScreen.tscn"
config/project_settings_override="user://override.cfg"
run/flush_stdout_on_print=true
boot_splash/image="res://Images/Splash/splash.png"
boot_splash/fullsize=false
boot_splash/bg_color=Color( 0.145098, 0.145098, 0.501961, 1 )
config/icon="res://icon.png"
config/windows_native_icon="res://icon.ico"

[autoload]

EventBus="*res://Autoloads/EventBus.gd"
ServiceLocator="*res://Core/ServiceLocator.gd"
PortableModeDetector="*res://Util/PortableModeDetector.gd"
Console="*res://UI/DebugUI/ConsoleSingleton.gd"
OPTIONS="*res://Game/Options/GlobalOptions.gd"
GlobalRegistry="*res://GlobalRegistry.gd"
GM="*res://Game/GM.gd"
SAVE="*res://Game/SaveManager.gd"
GlobalTooltip="*res://Game/UI/Tooltip/TooltipSystem.tscn"
AutoTranslation="*res://Util/AutoTranslation/AutoTranslation.gd"
CrotchFavBlocks="*res://Game/Datapacks/UI/CrotchCode/Util/CrotchFavBlocks.gd"
ModularDialogue="*res://Game/ModularDialogue/ModularDialogue.gd"
SexToyManager="*res://Util/SexToySupport/SexToyManager.gd"

[debug]

gdscript/warnings/treat_warnings_as_errors=true
gdscript/warnings/integer_division=false
gdscript/warnings/unsafe_cast=true

[display]

window/size/width=1280
window/size/height=720
window/dpi/allow_hidpi=true
window/handheld/orientation="sensor_landscape"
window/stretch/mode="2d"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PoolStringArray( "res://addons/godot-notes/plugin.cfg" )

[gui]

timers/tooltip_delay_sec=0.1

[importer_defaults]

texture={
"compress/bptc_ldr": 0,
"compress/hdr_mode": 0,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d": false,
"flags/anisotropic": false,
"flags/filter": true,
"flags/mipmaps": false,
"flags/repeat": 0,
"flags/srgb": 0,
"process/HDR_as_SRGB": false,
"process/fix_alpha_border": true,
"process/invert_color": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"size_limit": 0,
"stream": false,
"svg/scale": 1.0
}

[input]

touch={
"deadzone": 0.5,
"events": [ Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"button_mask":0,"position":Vector2( 0, 0 ),"global_position":Vector2( 0, 0 ),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"doubleclick":false,"script":null)
 ]
}
